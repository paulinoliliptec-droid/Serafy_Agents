# ─── LLM Providers ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Model used by each agent (override individually as needed)
ORCHESTRATOR_MODEL=gpt-4o
SUPPORT_MODEL=gpt-4o-mini
COMMERCIAL_MODEL=gpt-4o-mini
LEGAL_MODEL=gpt-4o
HR_MODEL=gpt-4o-mini
FINANCIAL_MODEL=gpt-4o
MARKETING_MODEL=gpt-4o-mini

# ─── LangSmith (observability) ───────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=agentOS-angola

# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO

# ─── Security ────────────────────────────────────────────────────────────────
API_SECRET_KEY=change-me-in-production
# Comma-separated list of allowed origins (CORS)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Checkpointer ────────────────────────────────────────────────────────────
# "memory" for local dev (in-process, no persistence between restarts)
# "firestore" for staging/production (persists state across sessions and instances)
CHECKPOINTER_BACKEND=memory

# ─── Firebase Authentication ─────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
# Leave empty on Cloud Run (uses ADC / Workload Identity automatically)
FIREBASE_CREDENTIALS_PATH=
# Locally: FIREBASE_CREDENTIALS_PATH=/path/to/service-account.json

# ─── WhatsApp Business API ────────────────────────────────────────────────────
# Token you choose and configure in the Meta App Dashboard → Webhooks
WHATSAPP_VERIFY_TOKEN=change-me-verify-token
# App Secret from Meta App Dashboard → Settings → Basic
WHATSAPP_APP_SECRET=
# System User permanent token from Meta Business Manager
WHATSAPP_API_TOKEN=
# Default tenant_id for sessions that originate from WhatsApp
WHATSAPP_DEFAULT_TENANT=default

# ─── GCP / Firestore ─────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=africa-south1
FIRESTORE_COLLECTION=agentos_checkpoints
# In Cloud Run: auth is automatic via Workload Identity / ADC (no key file needed)
# Locally: run `gcloud auth application-default login` or set GOOGLE_APPLICATION_CREDENTIALS
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
