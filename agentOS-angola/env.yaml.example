# Cloud Run env vars file — used with:
#   gcloud run deploy ... --env-vars-file env.yaml
#
# NOTE: Never commit the real env.yaml — add it to .gitignore.
# Sensitive values (API keys, tokens) should go into Secret Manager,
# not this file. See deploy.sh for the full secrets setup.

APP_ENV: production
APP_HOST: "0.0.0.0"
APP_PORT: "8080"
LOG_LEVEL: INFO

CHECKPOINTER_BACKEND: firestore
FIRESTORE_COLLECTION: agentos_checkpoints

GCP_PROJECT_ID: your-gcp-project-id
FIREBASE_PROJECT_ID: your-firebase-project-id

ORCHESTRATOR_MODEL: gpt-4o
SUPPORT_MODEL: gpt-4o-mini
COMMERCIAL_MODEL: gpt-4o-mini
LEGAL_MODEL: gpt-4o
HR_MODEL: gpt-4o-mini
FINANCIAL_MODEL: gpt-4o
MARKETING_MODEL: gpt-4o-mini

ALLOWED_ORIGINS: "https://your-frontend-domain.com"
WHATSAPP_DEFAULT_TENANT: default

LANGCHAIN_TRACING_V2: "false"
LANGCHAIN_PROJECT: agentOS-angola
